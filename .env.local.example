# ============================================================
# Roam — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ============================================================

# Supabase — find these in your project dashboard under Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase service role key — only used in migration scripts (never browser)
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Mapbox — find this in your Mapbox account under Access Tokens
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your-mapbox-token-here

# Migration helper — your Supabase user UUID (after first login)
# Run: supabase auth list  OR  check the users table in your dashboard
SEED_USER_ID=your-user-uuid-here
